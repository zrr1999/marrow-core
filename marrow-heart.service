[Unit]
Description=Marrow heartbeat scheduler
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/marrow-core
Environment=PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
ExecStart=/opt/marrow-core/.venv/bin/marrow run --config /workspace/marrow.toml --json-logs
Restart=always
RestartSec=5
StandardOutput=append:/var/lib/marrow/logs/heart.stdout.log
StandardError=append:/var/lib/marrow/logs/heart.stderr.log

[Install]
WantedBy=multi-user.target
