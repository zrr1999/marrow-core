<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.marrow.heart</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/marrow-core/.venv/bin/marrow</string>
    <string>run</string>
    <string>--config</string>
    <string>/Library/Application Support/marrow/marrow.toml</string>
    <string>--json-logs</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key><string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>WorkingDirectory</key>
  <string>/opt/marrow-core</string>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/var/lib/marrow/logs/heart.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/var/lib/marrow/logs/heart.stderr.log</string>
</dict>
</plist>
